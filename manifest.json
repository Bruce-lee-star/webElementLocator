{
  "manifest_version": 3,
  "name": "Web Element Selector",
  "version": "1.0",
  "description": "Advanced element locator with AI-powered xpath and css selector generation. Supports ChatGPT, Gemini, DeepSeek, and Claude.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
},
  
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.deepseek.com/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_title": "Web Element Selector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js", "lucide.js","error_handling_utils.js", "templates/*", "config.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
     "extension_pages": "script-src 'self'; object-src 'self';"
  }
}