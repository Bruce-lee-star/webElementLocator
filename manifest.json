{
  "manifest_version": 3,
  "name": "Web Element Selector",
  "version": "1.0",
  "description": "Web element locator tool for generating CSS and XPath selectors.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
},
  
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Web Element Selector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js", "lucide.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
     "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
